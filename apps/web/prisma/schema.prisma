// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum NotificationType {
  DISCUSSION_CREATED
  COMMENT_CREATED
  MENTION
}

model User {
  id            String            @id @default(cuid())
  email         String            @unique
  name          String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  ownedSpaces   Workspace[]
  memberships   WorkspaceMember[]
  discussions   Discussion[]
  comments      Comment[]
  notificationsReceived Notification[] @relation("NotificationRecipient")
  notificationsSent     Notification[] @relation("NotificationActor")
}

model Workspace {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  ownerId     String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  owner       User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members     WorkspaceMember[]
  discussions Discussion[]
  comments    Comment[]
  notifications Notification[]

  @@index([ownerId, createdAt])
  // Recommended (optional): @@index([createdAt]) for global recent-workspaces feeds.
}

model Discussion {
  id          String    @id @default(cuid())
  workspaceId String
  authorId    String
  title       String
  body        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments    Comment[]
  notifications Notification[]

  @@index([workspaceId, createdAt])
  @@index([workspaceId, id])
  @@index([authorId, createdAt])
  // Recommended (optional): @@index([workspaceId, updatedAt]) for active-discussion sort views.
}

model Comment {
  id              String    @id @default(cuid())
  discussionId    String
  workspaceId     String
  authorId        String
  parentCommentId String?
  depth           Int       @default(0)
  body            String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  discussion      Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  workspace       Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author          User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentComment   Comment?   @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies         Comment[]  @relation("CommentReplies")
  notifications   Notification[]

  @@index([discussionId, parentCommentId, id(sort: Desc)])
  @@index([workspaceId, discussionId, id(sort: Desc)])
  @@index([authorId, createdAt])
  // Recommended (optional): @@index([discussionId, createdAt]) for chronological thread views.
}

model Notification {
  id              String           @id @default(cuid())
  recipientUserId String
  actorUserId     String?
  workspaceId     String
  discussionId    String?
  commentId       String?
  type            NotificationType
  message         String
  metadata        Json?
  dedupeKey       String           @unique
  readAt          DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  recipient       User             @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  actor           User?            @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  discussion      Discussion?      @relation(fields: [discussionId], references: [id], onDelete: SetNull)
  comment         Comment?         @relation(fields: [commentId], references: [id], onDelete: SetNull)

  @@index([recipientUserId, id(sort: Desc)])
  @@index([recipientUserId, readAt, id(sort: Desc)])
  @@index([workspaceId, recipientUserId, id(sort: Desc)])
  @@index([discussionId, recipientUserId, id(sort: Desc)])
  // Recommended (optional): @@index([recipientUserId, createdAt]) for time-sorted analytics.
}

model WorkspaceMember {
  id          String         @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole  @default(MEMBER)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId, role])
  @@index([userId, createdAt])
  // Recommended (optional): @@index([userId, workspaceId, role]) for permission-heavy joins.
}
